{
  "name": "plantree",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "build:gh": "ng build --base-href \"https://radigirl.github.io/plantree-home/\"",
    "deploy:gh": "npx angular-cli-ghpages --dir=dist/plantree/browser",
    "redeploy": "npm run build:gh && npm run deploy:gh"
  },
  "private": true,
  "packageManager": "npm@11.11.0",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/service-worker": "^21.2.0",
    "@supabase/supabase-js": "^2.99.1",
    "angular-feather": "^6.5.1",
    "feather-icons": "^4.29.2",
    "lucide-angular": "^0.577.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.1",
    "@angular/cli": "^21.2.1",
    "@angular/compiler-cli": "^21.2.0",
    "angular-cli-ghpages": "^3.0.2",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
